# =============================================
# Public site config
# =============================================
NEXT_PUBLIC_BASE_URL=https://madureira.xyz
NEXT_PUBLIC_PORTFOLIO_URL=https://madureira.xyz
NEXT_PUBLIC_AVAILABLE_FOR_FREELANCE=true
NEXT_PUBLIC_DISCORD=https://discord.gg/your_discord_id

# =============================================
# GitHub
# =============================================
GITHUB_USERNAME=gmadureiraa
GITHUB_URL=https://github.com/gmadureiraa
REPO_NAME=portfolio
AVATAR_URL=https://github.com/gmadureiraa.png

# =============================================
# Newsletter — Upstash Redis (KV)
# Aceita também KV_REST_API_URL / KV_REST_API_TOKEN (alias Vercel KV)
# =============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================
# RESEND (multi-product)
# Wrapper em lib/integrations/resend/. Source-of-truth pra todos os projetos.
# Sem RESEND_API_KEY: o endpoint segue funcionando (Upstash dedupe + log).
#
# Domínios precisam estar verificados em https://resend.com/domains.
# Audiences pegar UUID em https://resend.com/audiences/<UUID>.
# =============================================

# --- API key ---
# Opção A (default): 1 chave compartilhada entre todos os produtos.
RESEND_API_KEY=
# Opção B: override por produto (sobrescreve A se setado). Use quando quiser
# rate limit / billing separado por projeto.
# RESEND_MADUREIRA_API_KEY=
# RESEND_VIRAL_API_KEY=
# RESEND_KALEIDOS_API_KEY=
# RESEND_AUTOBLOGGER_API_KEY=
# RESEND_REELS_API_KEY=

# --- Audiences (UUIDs do dashboard Resend) ---
RESEND_MADUREIRA_AUDIENCE_ID=
RESEND_VIRAL_AUDIENCE_ID=
RESEND_KALEIDOS_AUDIENCE_ID=
RESEND_AUTOBLOGGER_AUDIENCE_ID=
RESEND_REELS_AUDIENCE_ID=

# --- From emails (domínio verificado) ---
RESEND_MADUREIRA_FROM_EMAIL="Madureira <noreply@madureira.xyz>"
RESEND_VIRAL_FROM_EMAIL="Sequência Viral <noreply@viral.kaleidos.com.br>"
RESEND_KALEIDOS_FROM_EMAIL="Kaleidos <noreply@kaleidos.com.br>"
RESEND_AUTOBLOGGER_FROM_EMAIL="AutoBlogger <noreply@autoblogger.dev>"
RESEND_REELS_FROM_EMAIL="Reels Viral <noreply@reels-viral.com>"

# --- Owner (destino notify_owner, compartilhado) ---
OWNER_EMAIL=gf.madureiraa@gmail.com

# --- DEPRECATED (compat — só este projeto usa, novos projetos não) ---
# RESEND_AUDIENCE_ID=
# RESEND_FROM_EMAIL="Madureira <noreply@madureira.xyz>"

# Gmail SMTP fallback (/api/send-whatsapp-contact)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# =============================================
# Telegram contact bot
# =============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# =============================================
# Umami analytics (self-hosted)
# =============================================
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
